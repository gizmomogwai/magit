#!/bin/bash
os=$(uname)
args="--no-window-system --no-init-file --load $HOME/.magit/init.el"
prefix=
if [ "$#" -eq 1 ]; then
    cd $1
fi

if [ "$#" -eq 2 ]; then
    cd $1
    prefix="env SHA=$2"
fi

if [ $os == "Darwin" ]; then
  emacs_app=
  for candidate in \
    "$HOME/Applications/Emacs-30.2.app" \
    "$HOME/Applications/Emacs.app" \
    "/Applications/Emacs.app"; do
    if test -d "$candidate"; then
      emacs_app="$candidate/Contents/MacOS/Emacs"
      break
    fi
  done
  if test -z "$emacs_app"; then
    echo "No Emacs.app found" >&2
    exit 1
  fi
  $prefix "$emacs_app" $args
else
  $prefix emacs $args
fi
